// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InstagramPost {
  id               String   @id @default(uuid())
  instagramMediaId String   @unique
  caption          String?
  mediaType        String
  mediaUrl         String?
  thumbnailUrl     String?
  permalink        String
  timestamp        DateTime
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active])
  @@index([timestamp])
}

model ContactSubmission {
  id         String   @id @default(uuid())
  intent     String
  status     String   @default("unread")
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  role       String?
  experience String?
  trialDate  String?
  company    String?
  interest   String?
  website    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
  @@index([intent, createdAt])
}

model Sponsor {
  id           String   @id @default(uuid())
  name         String
  industry     String
  website      String?
  contactName  String?
  contactEmail String
  phone        String?
  logoUrl      String?
  logoPublicId String?
  active       Boolean  @default(true)
  featured     Boolean  @default(false)
  joinedAt     DateTime @default(now())
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, featured])
  @@index([joinedAt])
}

model Player {
  id                  String                   @id @default(uuid())
  firstName           String
  lastName            String
  displayName         String
  initials            String
  role                PlayerRole
  jerseyNumber        Int
  imageUrl            String?
  imagePublicId       String?
  playCricketPlayerId String?                  @unique
  battingAvg          Float                    @default(0)
  bestBowl            String                   @default("0/0")
  isCaptain           Boolean                  @default(false)
  isFeatured          Boolean                  @default(false)
  featuredStatValue   String?
  featuredStatLabel   String?
  active              Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  careerStats         PlayerCareerStats?
  matchPerformances   PlayerMatchPerformance[]
}

model PlayerCareerStats {
  id                   String   @id @default(uuid())
  playerId             String   @unique
  player               Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matches              Int      @default(0)
  battingInnings       Int      @default(0)
  battingAggregate     Int      @default(0)
  battingNotOuts       Int      @default(0)
  batting50s           Int      @default(0)
  batting100s          Int      @default(0)
  batting0s            Int      @default(0)
  battingHighScore     Int      @default(0)
  isBattingHSNotOut    Boolean  @default(false)
  battingAverage       Float    @default(0)
  battingStrikeRate    Float    @default(0)
  battingFours         Int      @default(0)
  battingSixes         Int      @default(0)
  bowlingWickets       Int      @default(0)
  bowlingMaidens       Int      @default(0)
  bowlingRuns          Int      @default(0)
  bowlingBalls         Int      @default(0)
  bowling5WIs          Int      @default(0)
  bowling10WMs         Int      @default(0)
  bowlingOvers         String   @default("0")
  bowlingBestInnings   String   @default("0-0")
  bowlingAverage       Float    @default(0)
  bowlingStrikeRate    Float    @default(0)
  bowlingEconomyRate   Float    @default(0)
  bowlingWides         Int      @default(0)
  bowlingNoBalls       Int      @default(0)
  fieldingCatchesNonWK Int      @default(0)
  fieldingCatchesWK    Int      @default(0)
  fieldingTotalCatches Int      @default(0)
  fieldingStumpings    Int      @default(0)
  fieldingRunOuts      Int      @default(0)
  syncedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PlayerMatchPerformance {
  id                     String   @id @default(uuid())
  playerId               String
  player                 Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  externalMatchId        String
  matchDate              DateTime
  matchType              String?
  gradeName              String?
  homeTeam               String?
  awayTeam               String?
  battingRuns            Int?
  battingBalls           Int?
  battingFours           Int?
  battingSixes           Int?
  battingStrikeRate      Float?
  battingDismissalTypeId Int?
  bowlingOvers           String?
  bowlingMaidens         Int?
  bowlingRuns            Int?
  bowlingWickets         Int?
  bowlingWides           Int?
  bowlingNoBalls         Int?
  bowlingEconomy         Float?
  fieldingCatches        Int?
  fieldingStumpings      Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([playerId, externalMatchId])
  @@index([playerId, matchDate])
}

enum PlayerRole {
  batsman
  bowler
  all_rounder
  wicket_keeper
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HomeContent {
  id            String   @id @default("home")
  matchesPlayed String   @default("48")
  victories     String   @default("31")
  trophies      String   @default("06")
  activePlayers String   @default("22")
  yearsActive   String   @default("01")
  tickerText    String   @default("Top G's CC def. Norwood CC by 47 runs    ·    Catto named Player of the Match    ·    Next fixture: Top G's CC vs Riverside CC — Sat 31 May    ·    U18s training every Thursday 5PM    ·    Season 2026 registrations now open    ·    ")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Fixture {
  id             String   @id @default(uuid())
  homeTeam       String
  awayTeam       String
  matchDate      DateTime
  time           String
  venueName      String
  venueGoogleUrl String?
  scoreboardUrl  String?
  matchLabel     String?
  season         String
  result         String   @default("upcoming")
  ourScore       String?
  oppScore       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([season, matchDate])
  @@index([result, matchDate])
}

model HonourTrophy {
  id          String   @id @default(uuid())
  year        Int
  title       String
  type        String   @default("Trophy")
  description String
  featured    Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year])
  @@index([featured])
}

model HonourAwardWinner {
  id        String   @id @default(uuid())
  season    String
  award     String
  name      String
  detail    String?
  featured  Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([season])
  @@index([featured])
}

model HonourManualRecord {
  id        String   @id
  label     String
  value     String
  meta      String?
  featured  Boolean  @default(true)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured])
  @@index([sortOrder])
}

model NewsPost {
  id            String      @id @default(uuid())
  title         String
  slug          String      @unique
  category      String
  layout        String      @default("standard")
  excerpt       String
  content       String
  featuredImage String?
  author        String      @default("Top G's CC")
  status        String      @default("draft")
  readTime      String      @default("1 min read")
  publishedAt   DateTime?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  blocks        NewsBlock[]

  @@index([status, publishedAt])
  @@index([category, publishedAt])
}

model NewsBlock {
  id        String   @id @default(uuid())
  postId    String
  post      NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      String
  sortOrder Int      @default(0)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, sortOrder])
}
